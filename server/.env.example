# 백엔드 환경변수. .env 는 절대 커밋하지 않는다(.env.example 만 제공).

# ── AI (RunYourAI — OpenAI 호환 게이트웨이로 GPT 호출, 운영자 키) ──────────────
# 운영자 키 하나로 모든 사용자 요청 처리(비용 운영자 부담). 프론트에 절대 노출 안 함.
RUNYOURAI_BASE_URL=https://<runyourai-host>/v1   # OpenAI 호환 base. 코드가 /chat/completions 를 붙임
RUNYOURAI_API_KEY=                                # RunYourAI API 키 (필수)
RUNYOURAI_MODEL=gpt-4.1                            # 모델명

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787
# 분리 배포(프론트 도메인 != 백엔드)일 때만 지정. same-origin 단일 배포면 비워둠.
# FRONTEND_ORIGIN=
