# ── GitHub OAuth App credentials ──────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# client_secret 는 절대 프론트로 노출하지 않는다. 서버 env 에만 둔다.
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# OAuth App 설정의 "Authorization callback URL" 과 정확히 일치해야 한다.
GITHUB_CALLBACK_URL=http://localhost:8787/api/auth/github/callback

# ── AI (RunYourAI — OpenAI 호환 게이트웨이, 운영자 키) ──────────────────────
# 운영자 키 하나로 GPT-4.1 호출(비용 운영자 부담). 프론트에 절대 노출 안 함(서버 env 전용).
RUNYOURAI_BASE_URL=https://<runyourai-host>/v1   # OpenAI 호환 base. 코드가 /chat/completions 를 붙임
RUNYOURAI_API_KEY=                                # RunYourAI API 키
RUNYOURAI_MODEL=gpt-4.1                            # 또는 openai/gpt-4.1-2025-04-14

# ── Session ────────────────────────────────────────────────────────────────
# 긴 랜덤 문자열. 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# ── Runtime ──────────────────────────────────────────────────────────────────
# development | production  (production 이면 Secure 쿠키 강제)
NODE_ENV=development

# https 스테이징 등 NODE_ENV!=production 이지만 Secure 쿠키가 필요할 때 true.
# (prod 면 자동 true) — 빈 값이면 NODE_ENV 기준.
COOKIE_SECURE=

# 프론트 오리진. CORS 허용 + OAuth 완료 후 리다이렉트 대상.
FRONTEND_ORIGIN=http://localhost:5173

# 서버 포트
PORT=8787
